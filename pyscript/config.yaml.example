# Copy relevant section to configuration.yaml on Home Assistant (pyscript: apps:).
# The app is enabled only when listed under pyscript.apps.
#
# Timer helpers (YAML or UI) require a full Home Assistant restart to appear in States.

timer:
  water_heating_boost:
    name: Water heating boost
    duration: "06:00:00"
    restore: true
  car_charging_boost:
    name: Car charging boost
    duration: "06:00:00"
    restore: true

pyscript:
  apps:
    shelly_cheap_intervals:
      # Nordpool sensor entity (Developer Tools -> States)
      nordpool_sensor: sensor.nordpool_kwh_fi_eur_3_10_022
      # Shelly (or any) switch to control
      shelly_switch: switch.shelly_outdoor_plug
      # Decimal hours; each 0.25 = one 15-minute interval (1.75 = 7 intervals)
      cheap_hours: 3.25
      boost_timer: timer.water_heating_boost
      boost_duration: "06:00:00"

    shelly_car_charging:
      nordpool_sensor: sensor.nordpool_kwh_fi_eur_3_10_022
      shelly_switch: switch.shelly_car_charger
      cheap_hours: 7
      night_start: 22
      night_end: 7
      boost_timer: timer.car_charging_boost
      boost_duration: "06:00:00"
